      object mi100: TMenuItem
        Caption = '100%'
        GroupIndex = 2
        RadioItem = True
        OnClick = miOpacityClick
      end
    end
    object N5: TMenuItem
      Caption = '-'
      GroupIndex = 3
    end
    object miAbout: TMenuItem
      Caption = 'about'
      GroupIndex = 3
      OnClick = miAboutClick
    end
  end
end
